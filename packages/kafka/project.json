{
  "name": "@idempo/kafka",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "options": {
        "outputPath": "dist/packages/kafka",
        "main": "packages/kafka/src/index.ts",
        "tsConfig": "packages/kafka/tsconfig.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/kafka/src/**/*.ts"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p packages/kafka/tsconfig.json"
      }
    }
  },
  "tags": ["scope:shared"]
}
