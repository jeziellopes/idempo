# ─── idempo — local development environment ──────────────────────────────────
# Copy this file to .env before running `docker compose up -d`.
# .env is gitignored; .env.example is committed.

# ── Identity Service (GitHub OAuth) ──────────────────────────────────────────
# Register an OAuth App at https://github.com/settings/developers
# Callback URL: http://localhost:3010/api/auth/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Required — must be ≥16 characters. Change before any shared/public deploy.
JWT_REFRESH_SECRET=idempo-local-refresh-secret-change-in-prod

# ── API Gateway ───────────────────────────────────────────────────────────────
# Required — must be ≥16 characters. Change this before any shared/public deploy.
JWT_SECRET=idempo-local-dev-secret-change-in-prod

# ── Apache Kafka ──────────────────────────────────────────────────────────────
# Required for KRaft mode — cluster identity UUID (base64-encoded).
# The default below is PUBLIC. Generate a new one for non-dev environments:
#   echo "$(uuidgen | tr -d '\n-' | base64)"
# KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qg==

# Optional — uncomment to override defaults
# PORT=3001
# METRICS_PORT=9091
# CORS_ORIGIN=http://localhost:3000

# ── Service URLs (used by API Gateway proxy) ──────────────────────────────────
# These are set automatically in docker-compose to use Docker service names.
# Override here only when running services on the host instead of in containers.
# GAME_SERVICE_URL=http://localhost:3002
# LEADERBOARD_SERVICE_URL=http://localhost:3005
# WALLET_SERVICE_URL=http://localhost:3004
# INVENTORY_SERVICE_URL=http://localhost:3006
# REWARD_SERVICE_URL=http://localhost:3007
# MARKETPLACE_SERVICE_URL=http://localhost:3008
# NOTIFICATION_SERVICE_URL=http://localhost:3009

# ── E2E tests ─────────────────────────────────────────────────────────────────
# Base URL the E2E suite uses to reach the API Gateway.
# API_URL=http://localhost:3001
