{
  "name": "e2e-ui",
  "projectType": "application",
  "sourceRoot": "apps/e2e-ui/src",
  "prefix": "e2e-ui",
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test",
        "cwd": "apps/e2e-ui"
      },
      "configurations": {
        "headed": {
          "command": "playwright test --headed --project=chromium"
        },
        "debug": {
          "command": "playwright test --debug"
        }
      }
    }
  },
  "tags": ["scope:app", "type:e2e"]
}
